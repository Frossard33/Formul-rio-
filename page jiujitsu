<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gilson Batista Jiu-Jitsu</title>
  <meta name="description" content="Base visual para site de academia de jiu-jitsu com foco em força, seriedade, autoridade e conversão de alunos." />
  <style>
    :root {
      --bg: #050505;
      --bg-soft: #0d0d0d;
      --bg-card: rgba(255, 255, 255, 0.04);
      --bg-card-strong: rgba(255, 255, 255, 0.06);
      --gold: #d4b06a;
      --gold-2: #8b6a3e;
      --gold-soft: rgba(212, 176, 106, 0.18);
      --red: #7a1414;
      --red-hover: #a61b1b;
      --white: #f5f5f5;
      --muted: #bdbdbd;
      --line: rgba(255, 255, 255, 0.08);
      --shadow: 0 20px 55px rgba(0, 0, 0, 0.45);
      --radius: 24px;
      --container: 1180px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      color: var(--white);
      background:
        radial-gradient(circle at top center, rgba(212,176,106,0.16) 0%, rgba(212,176,106,0.05) 16%, rgba(0,0,0,0) 38%),
        linear-gradient(135deg, #050505 0%, #101010 38%, #24170f 72%, #8b6a3e 100%);
      line-height: 1.6;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    .container {
      width: min(92%, var(--container));
      margin: 0 auto;
    }

    .section {
      padding: 92px 0;
    }

    .section-head {
      margin-bottom: 34px;
    }

    .eyebrow {
      display: inline-block;
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.82rem;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .section-title {
      font-size: clamp(2rem, 4vw, 3.2rem);
      line-height: 1.05;
      margin-bottom: 16px;
    }

    .section-text {
      max-width: 760px;
      color: var(--muted);
      font-size: 1.02rem;
    }

    .divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(212,176,106,0.4), transparent);
      margin-top: 28px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 50px;
      padding: 0 22px;
      border-radius: 999px;
      font-weight: 700;
      transition: 0.25s ease;
      border: 1px solid transparent;
      cursor: pointer;
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn-primary {
      color: white;
      background: linear-gradient(135deg, var(--red) 0%, var(--red-hover) 100%);
      box-shadow: 0 10px 28px rgba(122, 20, 20, 0.36);
    }

    .btn-secondary {
      background: rgba(255,255,255,0.03);
      border-color: rgba(212,176,106,0.36);
      color: var(--gold);
    }

    .btn-secondary:hover {
      background: rgba(212,176,106,0.08);
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(5, 5, 5, 0.78);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .nav {
      min-height: 80px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .brand-mark {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 1px solid rgba(212,176,106,0.32);
      background:
        radial-gradient(circle at 35% 28%, #e3c588 0%, #c99d59 25%, #8b6a3e 55%, #111111 100%);
      box-shadow: inset 0 0 18px rgba(0,0,0,0.48);
    }

    .brand-text strong {
      display: block;
      font-size: 1rem;
      letter-spacing: 0.03em;
    }

    .brand-text span {
      display: block;
      color: var(--muted);
      font-size: 0.82rem;
      margin-top: 2px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 22px;
      font-size: 0.95rem;
      color: var(--muted);
    }

    .nav-links a:hover {
      color: var(--gold);
    }

    .nav-cta {
      min-height: 42px;
      padding: 0 18px;
      font-size: 0.9rem;
    }

    .hero {
      padding: 86px 0 62px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      align-items: center;
      gap: 34px;
    }

    .hero h1 {
      font-size: clamp(2.8rem, 6vw, 5.4rem);
      line-height: 0.96;
      max-width: 760px;
      margin-bottom: 20px;
    }

    .hero h1 span {
      color: var(--gold);
    }

    .hero p {
      color: var(--muted);
      font-size: 1.08rem;
      max-width: 640px;
      margin-bottom: 28px;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 26px;
    }

    .hero-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .badge {
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      color: var(--muted);
      font-size: 0.92rem;
    }

    .hero-card {
      position: relative;
      min-height: 560px;
      border-radius: 30px;
      overflow: hidden;
      border: 1px solid rgba(212,176,106,0.16);
      background:
        radial-gradient(circle at top center, rgba(212,176,106,0.28), rgba(0,0,0,0) 42%),
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01)),
        linear-gradient(160deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
      box-shadow: var(--shadow);
      display: flex;
      align-items: flex-end;
      padding: 26px;
    }

    .hero-card::before {
      content: "";
      position: absolute;
      inset: 18px;
      border-radius: 22px;
      border: 1px solid rgba(212,176,106,0.10);
      pointer-events: none;
    }

    .hero-card::after {
      content: "LOGO / FOTO DA ACADEMIA";
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      font-size: 0.95rem;
      letter-spacing: 0.18em;
      color: rgba(255,255,255,0.12);
      text-transform: uppercase;
      pointer-events: none;
    }

    .hero-box {
      position: relative;
      z-index: 2;
      width: 100%;
      padding: 18px;
      border-radius: 20px;
      background: rgba(0,0,0,0.42);
      border: 1px solid rgba(255,255,255,0.06);
      backdrop-filter: blur(6px);
    }

    .hero-box h3 {
      color: var(--gold);
      font-size: 1.1rem;
      margin-bottom: 8px;
    }

    .hero-box p {
      margin: 0;
      font-size: 0.95rem;
      color: var(--muted);
    }

    .stats {
      margin-top: 28px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }

    .stat {
      padding: 24px 16px;
      text-align: center;
      border-radius: 20px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      backdrop-filter: blur(6px);
    }

    .stat strong {
      display: block;
      color: var(--gold);
      font-size: 1.9rem;
      line-height: 1;
      margin-bottom: 8px;
    }

    .stat span {
      font-size: 0.95rem;
      color: var(--muted);
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 34px;
      align-items: center;
    }

    .visual-box,
    .content-box,
    .card,
    .contact-card,
    .pricing-card,
    .testimonial,
    .gallery-item,
    .schedule-card,
    .faq-item,
    .cta-box {
      background: var(--bg-card);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .visual-box {
      min-height: 470px;
      position: relative;
      overflow: hidden;
      padding: 28px;
      display: flex;
      align-items: flex-end;
      background:
        radial-gradient(circle at top center, rgba(212,176,106,0.20), rgba(0,0,0,0) 38%),
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01));
    }

    .visual-box::before {
      content: "FOTO DO PROFESSOR / ACADEMIA";
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      font-size: 0.95rem;
      letter-spacing: 0.16em;
      color: rgba(255,255,255,0.12);
      text-transform: uppercase;
    }

    .visual-box .tag {
      position: relative;
      z-index: 2;
      display: inline-block;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(0,0,0,0.42);
      border: 1px solid rgba(212,176,106,0.20);
      color: var(--gold);
      font-weight: 700;
    }

    .content-box {
      padding: 32px;
    }

    .content-box p {
      color: var(--muted);
      margin-bottom: 14px;
    }

    .info-list {
      list-style: none;
      display: grid;
      gap: 12px;
      margin-top: 20px;
    }

    .info-list li {
      color: var(--muted);
      padding-left: 18px;
      position: relative;
    }

    .info-list li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--gold);
      font-weight: 700;
    }

    .cards-3,
    .cards-4,
    .testimonials,
    .gallery-grid,
    .pricing-grid,
    .faq-grid,
    .contact-grid {
      display: grid;
      gap: 22px;
    }

    .cards-3 { grid-template-columns: repeat(3, 1fr); }
    .cards-4 { grid-template-columns: repeat(4, 1fr); }
    .testimonials { grid-template-columns: repeat(3, 1fr); }
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
    .pricing-grid { grid-template-columns: repeat(3, 1fr); }
    .faq-grid { grid-template-columns: repeat(2, 1fr); }
    .contact-grid { grid-template-columns: 1.1fr 0.9fr; align-items: start; }

    .card,
    .pricing-card,
    .testimonial,
    .schedule-card,
    .faq-item,
    .contact-card,
    .cta-box {
      padding: 26px;
    }

    .card h3,
    .pricing-card h3,
    .testimonial h3,
    .schedule-card h3,
    .contact-card h3,
    .faq-item h3,
    .cta-box h3 {
      color: var(--gold);
      font-size: 1.18rem;
      margin-bottom: 12px;
    }

    .card p,
    .pricing-card p,
    .testimonial p,
    .schedule-card p,
    .contact-card p,
    .faq-item p,
    .cta-box p {
      color: var(--muted);
      font-size: 0.98rem;
    }

    .mini-label {
      display: inline-block;
      color: var(--gold);
      border: 1px solid rgba(212,176,106,0.24);
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 14px;
      font-weight: 700;
    }

    .card ul,
    .pricing-card ul,
    .schedule-card ul,
    .contact-list {
      list-style: none;
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .card li,
    .pricing-card li,
    .schedule-card li,
    .contact-list li {
      color: var(--muted);
      padding-left: 18px;
      position: relative;
    }

    .card li::before,
    .pricing-card li::before,
    .schedule-card li::before,
    .contact-list li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--gold);
      font-weight: 700;
    }

    .schedule-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .price {
      font-size: 2.2rem;
      color: var(--gold);
      font-weight: 700;
      line-height: 1;
      margin: 10px 0 12px;
    }

    .pricing-card.featured {
      border-color: rgba(212,176,106,0.30);
      background:
        radial-gradient(circle at top center, rgba(212,176,106,0.12), rgba(0,0,0,0) 46%),
        rgba(255,255,255,0.05);
      transform: translateY(-6px);
    }

    .gallery-item {
      position: relative;
      min-height: 260px;
      overflow: hidden;
      border-radius: 24px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
      border: 1px solid rgba(255,255,255,0.07);
    }

    .gallery-item::before {
      content: attr(data-label);
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: rgba(255,255,255,0.13);
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: 0.92rem;
    }

    .gallery-item::after {
      content: "";
      position: absolute;
      inset: auto 0 0 0;
      height: 90px;
      background: linear-gradient(180deg, rgba(0,0,0,0), rgba(0,0,0,0.82));
    }

    .gallery-caption {
      position: absolute;
      left: 20px;
      right: 20px;
      bottom: 18px;
      z-index: 2;
    }

    .gallery-caption strong {
      display: block;
      font-size: 1rem;
      margin-bottom: 4px;
    }

    .gallery-caption span {
      color: var(--muted);
      font-size: 0.92rem;
    }

    .testimonial .author {
      margin-top: 18px;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.07);
      color: var(--gold);
      font-weight: 700;
    }

    .contact-card strong {
      color: var(--white);
    }

    .student-showcase {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 22px;
      align-items: stretch;
    }

    .admin-preview,
    .student-journey,
    .feature-grid,
    .report-grid,
    .presence-grid,
    .belt-roadmap,
    .timeline-grid {
      display: grid;
      gap: 22px;
    }

    .admin-preview {
      grid-template-columns: 0.95fr 1.05fr;
      align-items: start;
    }

    .feature-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .report-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .presence-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .timeline-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .student-journey {
      grid-template-columns: repeat(3, 1fr);
    }

    .belt-roadmap {
      grid-template-columns: repeat(5, 1fr);
    }

    .login-mock,
    .dashboard-mock,
    .dash-card,
    .student-table,
    .student-banner,
    .admin-sidebar,
    .admin-content,
    .admin-widget,
    .roadmap-card,
    .journey-card,
    .report-card,
    .presence-card,
    .timeline-card {
      background: var(--bg-card);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .login-mock,
    .dashboard-mock,
    .admin-sidebar,
    .admin-content,
    .roadmap-card,
    .journey-card,
    .report-card,
    .presence-card,
    .timeline-card {
      padding: 26px;
    }

    .login-mock {
      background:
        radial-gradient(circle at top center, rgba(212,176,106,0.16), rgba(0,0,0,0) 42%),
        rgba(255,255,255,0.04);
    }

    .login-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 22px;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .login-pill {
      padding: 7px 12px;
      border-radius: 999px;
      font-size: 0.78rem;
      color: var(--gold);
      border: 1px solid rgba(212,176,106,0.24);
      background: rgba(255,255,255,0.03);
    }

    .mock-field {
      margin-bottom: 14px;
    }

    .mock-field label {
      display: block;
      font-size: 0.88rem;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .mock-input {
      width: 100%;
      min-height: 52px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      padding: 0 16px;
      color: rgba(255,255,255,0.55);
      display: flex;
      align-items: center;
    }

    .mock-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 20px;
    }

    .student-note {
      margin-top: 18px;
      color: var(--muted);
      font-size: 0.92rem;
    }

    .dashboard-mock {
      display: grid;
      gap: 18px;
    }

    .student-banner {
      padding: 20px;
      background:
        linear-gradient(135deg, rgba(122,20,20,0.22), rgba(212,176,106,0.10)),
        rgba(255,255,255,0.04);
    }

    .student-banner strong {
      display: block;
      color: var(--gold);
      font-size: 1.1rem;
      margin-bottom: 8px;
    }

    .dash-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    .dash-card {
      padding: 18px;
      min-height: 112px;
    }

    .dash-card span {
      display: block;
      color: var(--muted);
      font-size: 0.84rem;
      margin-bottom: 8px;
    }

    .dash-card strong {
      display: block;
      color: var(--gold);
      font-size: 1.5rem;
      line-height: 1;
      margin-bottom: 6px;
    }

    .dash-card p {
      color: var(--muted);
      font-size: 0.9rem;
    }

    .student-table {
      padding: 18px;
    }

    .table-head,
    .table-row {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 12px;
      align-items: center;
    }

    .table-head {
      color: var(--gold);
      font-size: 0.84rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      margin-bottom: 10px;
    }

    .table-row {
      min-height: 54px;
      color: var(--muted);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.94rem;
    }

    .table-row:last-child {
      border-bottom: 0;
    }

    .status-ok,
    .status-warn,
    .belt-tag,
    .nav-chip,
    .presence-tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 0 10px;
      border-radius: 999px;
      font-size: 0.8rem;
      width: fit-content;
    }

    .status-ok {
      color: #d5f5da;
      background: rgba(32, 108, 54, 0.32);
      border: 1px solid rgba(102, 187, 106, 0.18);
    }

    .status-warn {
      color: #ffe3b4;
      background: rgba(122, 78, 20, 0.26);
      border: 1px solid rgba(212,176,106,0.18);
    }

    .belt-tag,
    .nav-chip,
    .presence-tag {
      color: var(--white);
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .admin-sidebar {
      background:
        radial-gradient(circle at top center, rgba(212,176,106,0.14), rgba(0,0,0,0) 40%),
        rgba(255,255,255,0.04);
    }

    .admin-brand {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 22px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .admin-dot {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 28%, #e3c588 0%, #c99d59 25%, #8b6a3e 55%, #111111 100%);
      border: 1px solid rgba(212,176,106,0.3);
    }

    .admin-menu {
      display: grid;
      gap: 12px;
      margin-bottom: 20px;
    }

    .admin-menu-item {
      min-height: 52px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.05);
      color: var(--muted);
    }

    .admin-menu-item strong {
      color: var(--white);
      font-size: 0.96rem;
    }

    .admin-content {
      display: grid;
      gap: 18px;
    }

    .admin-topbar {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: center;
      padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .admin-topbar p {
      color: var(--muted);
      margin: 6px 0 0;
    }

    .admin-top-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .admin-widget {
      padding: 18px;
    }

    .admin-widget h4,
    .report-card h4,
    .presence-card h4,
    .roadmap-card h4,
    .journey-card h4,
    .timeline-card h4 {
      color: var(--gold);
      margin-bottom: 10px;
      font-size: 1rem;
    }

    .admin-widget p,
    .report-card p,
